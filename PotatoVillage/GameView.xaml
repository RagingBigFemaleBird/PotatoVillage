<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PotatoVillage.GameView"
             Shell.NavBarIsVisible="False">

    <!-- Orange border around entire UI -->
    <Border Stroke="Orange" 
            StrokeThickness="3" 
            StrokeShape="RoundRectangle 4"
            Padding="0"
            Margin="2">

        <!-- Custom compact toolbar -->
        <Grid RowDefinitions="24,*">
        <HorizontalStackLayout Grid.Row="0" 
                               BackgroundColor="#6200EE"
                               HorizontalOptions="End"
                               Spacing="8"
                               Padding="8,0">
            <Button x:Name="RevealBtn"
                    Text="Reveal"
                    Clicked="OnRevealClicked"
                    HeightRequest="22"
                    FontSize="11"
                    Padding="8,0"
                    BackgroundColor="Transparent"
                    TextColor="White" />
            <Button Text="?"
                    Clicked="OnDisconnectClicked"
                    HeightRequest="22"
                    FontSize="11"
                    Padding="8,0"
                    BackgroundColor="Transparent"
                    TextColor="White" />
        </HorizontalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="1*,2*" RowDefinitions="*">
            <!-- Left side: Player ID display (1/3 of screen) -->
            <Grid Grid.Column="0" RowDefinitions="1*,Auto,1*">
                <!-- Top: Upside down player ID -->
                <Label x:Name="PlayerIdTopLabel"
                   Grid.Row="0"
                   FontSize="200"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   Rotation="180"
                   TextColor="Blue"
                   Opacity="1">
                <Label.FontSize>
                    <OnPlatform x:TypeArguments="x:Double">
                        <On Platform="Android,iOS">200</On>
                    </OnPlatform>
                </Label.FontSize>
            </Label>

            <!-- Thick separator line -->
            <BoxView Grid.Row="1"
                     HeightRequest="4"
                     BackgroundColor="Black"
                     HorizontalOptions="Fill"
                     Margin="20,0" />

            <!-- Bottom: Normal player ID -->
            <Label x:Name="PlayerIdBottomLabel"
                   Grid.Row="2"
                   FontSize="200"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   TextColor="Blue"
                   Opacity="1">
                <Label.FontSize>
                    <OnPlatform x:TypeArguments="x:Double">
                        <On Platform="Android,iOS">200</On>
                    </OnPlatform>
                </Label.FontSize>
            </Label>
        </Grid>

        <!-- Right side: Target selection (top 3/4), Status bar and Counter (bottom 1/4) -->
        <Grid Grid.Column="1" RowDefinitions="3*,1*">
            <!-- Top 3/4: Target selection area -->
            <ScrollView Grid.Row="0" Padding="5">
                <VerticalStackLayout Spacing="8">
                    <!-- Target selection area (initially hidden) -->
                    <Frame x:Name="TargetSelectionContainer" 
                           IsVisible="False"
                           Padding="10"
                           CornerRadius="8"
                           BackgroundColor="#F0F0F0"
                           HasShadow="True">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Label x:Name="TargetInstructionLabel" 
                                   Grid.Row="0"
                                   Text="" 
                                   FontSize="18"
                                   TextColor="#666666" />

                            <!-- Target buttons container -->
                            <FlexLayout x:Name="TargetButtonsContainer"
                                        Grid.Row="1"
                                        Wrap="Wrap"
                                        JustifyContent="Start"
                                        AlignItems="Center"
                                        AlignContent="Start"
                                        Direction="Row"
                                        MinimumHeightRequest="50"
                                        Margin="0,8,0,0" />

                            <!-- Bottom row: Confirm button and Sheriff status -->
                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                                <!-- Confirm button -->
                                <Button x:Name="ConfirmButton"
                                        Grid.Column="0"
                                        Text="Confirmed"
                                        IsVisible="False"
                                        Clicked="OnConfirmClicked"
                                        BackgroundColor="#007AFF"
                                        TextColor="White"
                                        FontSize="18"
                                        Padding="8,4"
                                        HorizontalOptions="Start" />

                                <!-- Current Sheriff status label -->
                                <Label x:Name="CurrentSheriffLabel"
                                       Grid.Column="1"
                                       Text=""
                                       FontSize="14"
                                       TextColor="#888888"
                                       FontAttributes="Italic"
                                       VerticalOptions="Center"
                                       HorizontalOptions="End" />
                            </Grid>
                        </Grid>
                    </Frame>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Bottom 1/4: Status bar (6 parts) and Counter (1 part) -->
            <Grid Grid.Row="1" ColumnDefinitions="6*,1*" Padding="5,0">
                <!-- Left 6/7: Game Status -->
                <Frame x:Name="GameStatusFrame"
                       Grid.Column="0" 
                       Padding="10"
                       CornerRadius="8"
                       HasShadow="False"
                       BackgroundColor="#F8F8F8"
                       BorderColor="#E0E0E0">
                    <Grid>
                        <Label x:Name="GameStatusLabel" 
                               Text="" 
                               LineBreakMode="TailTruncation"
                               FontSize="20"
                               MaxLines="3"
                               VerticalOptions="Center"
                               HorizontalOptions="Start"
                               VerticalTextAlignment="Center"
                               HorizontalTextAlignment="Start" />

                        <!-- Announcer Toggle Button - Bottom Right of status bar -->
                        <Button x:Name="AnnouncerBtn"
                                Text="🔇"
                                FontSize="10"
                                WidthRequest="25"
                                HeightRequest="25"
                                CornerRadius="12"
                                BackgroundColor="LightGray"
                                HorizontalOptions="End"
                                VerticalOptions="End"
                                Clicked="OnAnnouncerToggleClicked" />
                    </Grid>
                </Frame>

                <!-- Right 1/7: Countdown timer -->
                <Frame Grid.Column="1" 
                       Padding="5"
                       CornerRadius="8"
                       HasShadow="False"
                       BackgroundColor="#FFE0E0"
                       BorderColor="#FF8080"
                       Margin="5,0,0,0">
                    <Label x:Name="CountdownLabel" 
                           Text=""
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="Red"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>
            </Grid>
        </Grid>
        </Grid>
    </Grid>
    </Border>

</ContentPage>
