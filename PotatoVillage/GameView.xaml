<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PotatoVillage.GameView">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="?" Clicked="OnDisconnectClicked" Priority="1" />
    </ContentPage.ToolbarItems>

    <Grid ColumnDefinitions="2*,1*" RowDefinitions="*">
        <!-- Left side: Player ID display (2/3 of screen) -->
        <Grid Grid.Column="0" RowDefinitions="1*,1*">
            <!-- Top: Upside down player ID -->
            <Label x:Name="PlayerIdTopLabel"
                   Grid.Row="0"
                   FontSize="200"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   Rotation="180"
                   TextColor="Blue"
                   Opacity="1">
                <Label.FontSize>
                    <OnPlatform x:TypeArguments="x:Double">
                        <On Platform="Android,iOS">200</On>
                    </OnPlatform>
                </Label.FontSize>
            </Label>

            <!-- Bottom: Normal player ID -->
            <Label x:Name="PlayerIdBottomLabel"
                   Grid.Row="1"
                   FontSize="200"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   TextColor="Blue"
                   Opacity="1">
                <Label.FontSize>
                    <OnPlatform x:TypeArguments="x:Double">
                        <On Platform="Android,iOS">200</On>
                    </OnPlatform>
                </Label.FontSize>
            </Label>
        </Grid>

        <!-- Right side: Game status (1/3), controls (1/3), and timer (1/3) -->
        <Grid Grid.Column="1" RowDefinitions="1*,2*,1*">
            <!-- Top 1/3: Game Status -->
            <Frame Grid.Row="0" 
                   Padding="10"
                   CornerRadius="0"
                   HasShadow="False"
                   BackgroundColor="Transparent"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="8" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
                    <Label x:Name="GameStatusLabel" 
                           Text="" 
                           LineBreakMode="WordWrap"
                           FontSize="12"
                           VerticalOptions="FillAndExpand"
                           HorizontalOptions="FillAndExpand"
                           VerticalTextAlignment="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- Middle 1/3: Game info and controls -->
            <ScrollView Grid.Row="1" Padding="10">
                <VerticalStackLayout Spacing="12">

                    <!-- Start Game Button (only for owner) -->
                    <Button x:Name="StartGameBtn"
                            Text="Start Game"
                            IsVisible="False"
                            Clicked="OnStartGameClicked"
                            BackgroundColor="#007AFF"
                            TextColor="White"
                            Margin="0,12,0,0" />

                    <!-- Target selection area (initially hidden) -->
                    <Frame x:Name="TargetSelectionContainer" 
                           IsVisible="False"
                           Padding="8"
                           CornerRadius="8"
                           BackgroundColor="#F0F0F0"
                           HasShadow="True"
                           Margin="0,12,0,0">
                        <StackLayout Spacing="8">
                            <Label x:Name="TargetInstructionLabel" 
                                   Text="" 
                                   FontSize="15"
                                   TextColor="#666666" />
                            
                            <!-- Target buttons container -->
                            <FlexLayout x:Name="TargetButtonsContainer"
                                        Wrap="Wrap"
                                        JustifyContent="Start"
                                        AlignItems="Center"
                                        Margin="0,8,0,0" />
                            
                            <!-- Confirm button -->
                            <Button x:Name="ConfirmButton"
                                    Text="Confirmed"
                                    IsVisible="False"
                                    Clicked="OnConfirmClicked"
                                    Margin="0,8,0,0"
                                    BackgroundColor="#007AFF"
                                    TextColor="White"
                                    FontSize="12"
                                    Padding="8,4" />
                        </StackLayout>
                    </Frame>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Bottom 1/3: Countdown timer -->
            <Frame Grid.Row="2" 
                   Padding="0"
                   CornerRadius="0"
                   HasShadow="False"
                   BackgroundColor="Transparent"
                   BorderColor="Transparent">
                <Grid BackgroundColor="Transparent" Padding="0">
                    <Label x:Name="CountdownLabel" 
                           Text=""
                           FontSize="80"
                           FontAttributes="Bold"
                           TextColor="Red"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Grid>
            </Frame>
        </Grid>
    </Grid>

</ContentPage>
