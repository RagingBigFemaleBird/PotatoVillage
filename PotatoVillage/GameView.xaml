<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PotatoVillage.GameView"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!-- Background Image -->
        <Image Source="bg.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />


        <Grid RowDefinitions="3*,6*,8*,25*,3*">
            <!-- Top 3/46: Toolbar row (Player ID, Game Status, Countdown) -->
            <Grid Grid.Row="0" 
                  ColumnDefinitions="2*,18*,3*"
                  BackgroundColor="#00000000"
                  Padding="4,0">

                <!-- Player ID -->
                <Label x:Name="PlayerIdLabel"
                       Grid.Column="0"
                       FontSize="16"
                       TextColor="#FFFFFF00"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       VerticalOptions="Center"
                       HorizontalOptions="Fill"
                       Margin="2" />

                <!-- Game Status -->
                <Border x:Name="GameStatusFrame"
                        Grid.Column="1"
                        Padding="4,0"
                        StrokeShape="RoundRectangle 4"
                        BackgroundColor="#F8F8F8"
                        Stroke="#E0E0E0"
                        Margin="2"
                        VerticalOptions="Fill">
                    <Label x:Name="GameStatusLabel" 
                           Text="" 
                           LineBreakMode="TailTruncation"
                           FontSize="12"
                           MaxLines="2"
                           TextColor="Teal"
                           VerticalOptions="Center"
                           HorizontalOptions="Start"
                           VerticalTextAlignment="Center"
                           HorizontalTextAlignment="Start" />
                </Border>

                <!-- Countdown timer -->
                <Border Grid.Column="2"
                        Padding="2,0"
                        StrokeShape="RoundRectangle 4"
                        BackgroundColor="#FFE0E0"
                        Stroke="#FF8080"
                        Margin="2"
                        VerticalOptions="Fill">
                    <Label x:Name="CountdownLabel" 
                           Text=""
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="Red"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- Row 1: Target instruction label -->
            <Label x:Name="TargetInstructionLabel"
                   Grid.Row="1"
                   Text="" 
                   FontSize="14"
                   TextColor="Brown"
                   IsVisible="False"
                   VerticalTextAlignment="Center"
                   Padding="10,0"
                   BackgroundColor="#FFFDD0" />

            <!-- Row 2: Special target buttons (e.g. Do not attack, Save, Abstain) -->
            <Border x:Name="SpecialTargetSelectionContainer"
                    Grid.Row="2"
                    IsVisible="False"
                    Padding="5"
                    Margin="5,0"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="#00000000"
                    Stroke="Transparent"
                    VerticalOptions="Fill"
                    HorizontalOptions="Fill">
                <ScrollView Orientation="Horizontal">
                    <FlexLayout x:Name="SpecialTargetButtonsContainer"
                                Wrap="Wrap"
                                JustifyContent="Start"
                                AlignItems="Center"
                                AlignContent="Start"
                                Direction="Row"
                                MinimumHeightRequest="30" />
                </ScrollView>
            </Border>

            <!-- Row 3: Regular target selection area (player buttons) -->
            <Border x:Name="TargetSelectionContainer" 
                    Grid.Row="3"
                    IsVisible="False"
                    Padding="10"
                    Margin="5"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="#00000000"
                    Stroke="Transparent"
                    VerticalOptions="Fill"
                    HorizontalOptions="Fill">
                <ScrollView>
                    <FlexLayout x:Name="TargetButtonsContainer"
                                Wrap="Wrap"
                                JustifyContent="Start"
                                AlignItems="Center"
                                AlignContent="Start"
                                Direction="Row"
                                MinimumHeightRequest="50" />
                </ScrollView>
            </Border>

            <!-- Bottom bar: Confirm, Sheriff, Reveal, Mute, Leave -->
            <Grid Grid.Row="4"
                  ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                  BackgroundColor="#F0F0F0"
                  Padding="6,0">

                <!-- Confirm button -->
                <Button x:Name="ConfirmButton"
                        Grid.Column="0"
                        Text="Confirmed"
                        IsVisible="False"
                        Clicked="OnConfirmClicked"
                        BackgroundColor="#007AFF"
                        TextColor="White"
                        FontSize="11"
                        Padding="8,0"
                        Margin="0,0,4,0"
                        HeightRequest="20"
                        VerticalOptions="Center" />

                <!-- Sheriff status label -->
                <Label x:Name="CurrentSheriffLabel"
                       Grid.Column="1"
                       Text=""
                       FontSize="12"
                       TextColor="#888888"
                       FontAttributes="Italic"
                       VerticalOptions="Center"
                       HorizontalOptions="Start" />

                <!-- Reveal button -->
                <Button x:Name="RevealBtn"
                        Grid.Column="2"
                        Text="Reveal"
                        Clicked="OnRevealClicked"
                        FontSize="11"
                        Padding="8,0"
                        Margin="4,0"
                        HeightRequest="20"
                        TextColor="White"
                        VerticalOptions="Center" />

                <!-- Announcer Toggle Button -->
                <Button x:Name="AnnouncerBtn"
                        Grid.Column="3"
                        Text="×"
                        FontSize="10"
                        WidthRequest="15"
                        HeightRequest="15"
                        CornerRadius="10"
                        Padding="0"
                        Margin="4,0"
                        BackgroundColor="LightGray"
                        VerticalOptions="Center"
                        Clicked="OnAnnouncerToggleClicked" />

                <!-- Disconnect button -->
                <Button Text="X"
                        Grid.Column="4"
                        Clicked="OnDisconnectClicked"
                        FontSize="11"
                        Padding="8,0"
                        Margin="4,0"
                        HeightRequest="15"
                        BackgroundColor="#FF4444"
                        TextColor="White"
                        VerticalOptions="Center" />
            </Grid>
        </Grid>
    </Grid>

</ContentPage>
