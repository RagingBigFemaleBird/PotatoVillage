<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PotatoVillage.GameView">

    <ContentPage.ToolbarItems>
        <ToolbarItem x:Name="RevealBtn"
                     Text="Reveal"
                     Clicked="OnRevealClicked"
                     Priority="0" />
        <ToolbarItem Text="?"
                     Clicked="OnDisconnectClicked"
                     Priority="1" />
    </ContentPage.ToolbarItems>

    <Grid ColumnDefinitions="1*,2*" RowDefinitions="*">
        <!-- Left side: Player ID display (1/3 of screen) -->
        <Grid Grid.Column="0" RowDefinitions="1*,Auto,1*">
            <!-- Top: Upside down player ID -->
            <Label x:Name="PlayerIdTopLabel"
                   Grid.Row="0"
                   FontSize="200"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   Rotation="180"
                   TextColor="Blue"
                   Opacity="1">
                <Label.FontSize>
                    <OnPlatform x:TypeArguments="x:Double">
                        <On Platform="Android,iOS">200</On>
                    </OnPlatform>
                </Label.FontSize>
            </Label>

            <!-- Thick separator line -->
            <BoxView Grid.Row="1"
                     HeightRequest="4"
                     BackgroundColor="Black"
                     HorizontalOptions="Fill"
                     Margin="20,0" />

            <!-- Bottom: Normal player ID -->
            <Label x:Name="PlayerIdBottomLabel"
                   Grid.Row="2"
                   FontSize="200"
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   TextColor="Blue"
                   Opacity="1">
                <Label.FontSize>
                    <OnPlatform x:TypeArguments="x:Double">
                        <On Platform="Android,iOS">200</On>
                    </OnPlatform>
                </Label.FontSize>
            </Label>
        </Grid>

        <!-- Right side: Game status (1/3), controls (1/3), and timer (1/3) -->
        <Grid Grid.Column="1" RowDefinitions="1*,4*,1*">
            <!-- Top 1/3: Game Status -->
            <Frame x:Name="GameStatusFrame"
                   Grid.Row="0" 
                   Padding="0"
                   CornerRadius="0"
                   HasShadow="False"
                   BackgroundColor="Transparent"
                   BorderColor="Transparent">
                <VerticalStackLayout Spacing="8" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
                    <Label x:Name="GameStatusLabel" 
                           Text="" 
                           LineBreakMode="TailTruncation"
                           FontSize="14"
                           MaxLines="2"
                           VerticalOptions="FillAndExpand"
                           HorizontalOptions="FillAndExpand"
                           VerticalTextAlignment="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- Middle 1/3: Game info and controls -->
            <ScrollView Grid.Row="1" Padding="0">
                <VerticalStackLayout Spacing="12">

                    <!-- Target selection area (initially hidden) -->
                    <Frame x:Name="TargetSelectionContainer" 
                           IsVisible="False"
                           Padding="0"
                           CornerRadius="8"
                           BackgroundColor="#F0F0F0"
                           HasShadow="True"
                           Margin="0,12,0,0">
                        <StackLayout Spacing="8">
                            <Label x:Name="TargetInstructionLabel" 
                                   Text="" 
                                   FontSize="18"
                                   TextColor="#666666" />
                            
                            <!-- Target buttons container -->
                            <FlexLayout x:Name="TargetButtonsContainer"
                                        Wrap="Wrap"
                                        JustifyContent="Start"
                                        AlignItems="Center"
                                        Margin="0,8,0,0" />
                            
                            <!-- Confirm button -->
                            <Button x:Name="ConfirmButton"
                                    Text="Confirmed"
                                    IsVisible="False"
                                    Clicked="OnConfirmClicked"
                                    Margin="0,8,0,0"
                                    BackgroundColor="#007AFF"
                                    TextColor="White"
                                    FontSize="18"
                                    Padding="8,4" />
                        </StackLayout>
                    </Frame>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Bottom 1/3: Countdown timer -->
            <Frame Grid.Row="2" 
                   Padding="0"
                   CornerRadius="0"
                   HasShadow="False"
                   BackgroundColor="Transparent"
                   BorderColor="Transparent">
                <Grid BackgroundColor="Transparent" Padding="0">
                    <Label x:Name="CountdownLabel" 
                           Text=""
                           FontSize="40"
                           FontAttributes="Bold"
                           TextColor="Red"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />

                    <!-- Announcer Toggle Button - Bottom Right -->
                    <Button x:Name="AnnouncerBtn"
                            Text="🔇"
                            FontSize="10"
                            WidthRequest="25"
                            HeightRequest="25"
                            CornerRadius="12"
                            BackgroundColor="LightGray"
                            HorizontalOptions="End"
                            VerticalOptions="End"
                            Margin="0,0,10,10"
                            Clicked="OnAnnouncerToggleClicked" />
                </Grid>
            </Frame>
        </Grid>
    </Grid>

</ContentPage>
