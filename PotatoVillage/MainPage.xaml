<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:PotatoVillage.Markup"
             x:Class="PotatoVillage.MainPage">

    <Grid>
        <!-- Background Image -->
        <Image Source="bg.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />

        <Grid RowDefinitions="Auto,*" Padding="20">
        <!-- Top: Nickname Entry -->
        <Entry x:Name="NicknameEntry" 
               Grid.Row="0"
               Placeholder="{m:Translate nickname_optional}" 
               FontSize="18"
               TextColor="#FFF8DC"
               Margin="0,10,0,20" />

        <!-- Main buttons filling the rest of the view -->
        <Grid Grid.Row="1" RowDefinitions="*,*,*,*" RowSpacing="15" Margin="30">
            <Button x:Name="JoinGameBtn" 
                    Grid.Row="0"
                    Text="{m:Translate join_existing_game}" 
                    Clicked="OnJoinGameClicked"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="24"
                    FontAttributes="Bold"
                    CornerRadius="20" />

            <Button x:Name="CreateGameBtn" 
                    Grid.Row="1"
                    Text="{m:Translate create_game}" 
                    Clicked="OnCreateGameClicked"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="24"
                    FontAttributes="Bold"
                    CornerRadius="20" />

            <Button x:Name="ChangeServerBtn" 
                    Grid.Row="2"
                    Text="{m:Translate change_server}" 
                    Clicked="OnChangeServerClicked"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="24"
                    FontAttributes="Bold"
                    CornerRadius="20" />

            <Button x:Name="AboutBtn" 
                    Grid.Row="3"
                    Text="{m:Translate about}" 
                    Clicked="OnAboutClicked"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    FontSize="24"
                    FontAttributes="Bold"
                    CornerRadius="20" />
        </Grid>
            </Grid>
        </Grid>

    </ContentPage>
