<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PotatoVillage.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="PotatoVillage - Game Client" FontAttributes="Bold" FontSize="18" />

            <Entry x:Name="NicknameEntry" Placeholder="Nickname (optional)" />
            <Entry x:Name="HubUrlEntry" Text="http://localhost:5269/gamehub" Placeholder="Hub URL" />

            <HorizontalStackLayout Spacing="8">
                <Button x:Name="ConnectBtn" Text="Connect" Clicked="OnConnectClicked" />
            </HorizontalStackLayout>

            <!-- Role Selection Section -->
            <Label Text="Select Roles for New Game" FontAttributes="Bold" FontSize="14" Margin="0,12,0,0" />
            
            <!-- Row 1: LangRen (5 buttons) -->
            <HorizontalStackLayout Spacing="4">
                <Button x:Name="LangRen1Btn" Text="L1" Clicked="OnLangRenClicked" BackgroundColor="LightGray" WidthRequest="40" />
                <Button x:Name="LangRen2Btn" Text="L2" Clicked="OnLangRenClicked" BackgroundColor="LightGray" WidthRequest="40" />
                <Button x:Name="LangRen3Btn" Text="L3" Clicked="OnLangRenClicked" BackgroundColor="LightGray" WidthRequest="40" />
                <Button x:Name="LangRen4Btn" Text="L4" Clicked="OnLangRenClicked" BackgroundColor="LightGray" WidthRequest="40" />
                <Button x:Name="LangRen5Btn" Text="L5" Clicked="OnLangRenClicked" BackgroundColor="LightGray" WidthRequest="40" />
            </HorizontalStackLayout>

            <!-- Row 2: JiaMian (1 button) -->
            <HorizontalStackLayout Spacing="4">
                <Button x:Name="JiaMianBtn" Text="JiaMian" Clicked="OnJiaMianClicked" BackgroundColor="LightGray" />
            </HorizontalStackLayout>

            <!-- Row 3: NvWu, YuYanJia, WuZhe -->
            <HorizontalStackLayout Spacing="4">
                <Button x:Name="NvWuBtn" Text="NvWu" Clicked="OnNvWuClicked" BackgroundColor="LightGray" />
                <Button x:Name="YuYanJiaBtn" Text="YuYanJia" Clicked="OnYuYanJiaClicked" BackgroundColor="LightGray" />
                <Button x:Name="WuZheBtn" Text="WuZhe" Clicked="OnWuZheClicked" BackgroundColor="LightGray" />
            </HorizontalStackLayout>

            <!-- Row 4: PingMin (5 buttons) -->
            <HorizontalStackLayout Spacing="4">
                <Button x:Name="PingMin1Btn" Text="P1" Clicked="OnPingMinClicked" BackgroundColor="LightGray" WidthRequest="40" />
                <Button x:Name="PingMin2Btn" Text="P2" Clicked="OnPingMinClicked" BackgroundColor="LightGray" WidthRequest="40" />
                <Button x:Name="PingMin3Btn" Text="P3" Clicked="OnPingMinClicked" BackgroundColor="LightGray" WidthRequest="40" />
                <Button x:Name="PingMin4Btn" Text="P4" Clicked="OnPingMinClicked" BackgroundColor="LightGray" WidthRequest="40" />
                <Button x:Name="PingMin5Btn" Text="P5" Clicked="OnPingMinClicked" BackgroundColor="LightGray" WidthRequest="40" />
            </HorizontalStackLayout>

            <!-- Join Existing Game Section -->
            <Label Text="Join Existing Game" FontAttributes="Bold" FontSize="14" Margin="0,12,0,0" />
            <HorizontalStackLayout Spacing="8">
                <Entry x:Name="RoomNumberEntry" Placeholder="Room #" WidthRequest="100" Keyboard="Numeric" />
                <Entry x:Name="SeatNumberEntry" Placeholder="Seat #" WidthRequest="100" Keyboard="Numeric" />
                <Button x:Name="JoinBtn" Text="Join" Clicked="OnJoinClicked" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
