<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PotatoVillage.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="PotatoVillage - Game Client" FontAttributes="Bold" FontSize="18" />

            <Entry x:Name="HubUrlEntry" Text="http://localhost:5269/gamehub" Placeholder="Hub URL" />
            <HorizontalStackLayout Spacing="8">
                <Entry x:Name="GameIdEntry" Placeholder="Game Id" WidthRequest="120" Keyboard="Numeric" />
                <Entry x:Name="PlayerIdEntry" Placeholder="Player Id" WidthRequest="120" Keyboard="Numeric" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="8">
                <Button x:Name="ConnectBtn" Text="Connect" Clicked="OnConnectClicked" />
                <Button x:Name="StartGameBtn" Text="Start Game" Clicked="OnStartGameClicked" IsEnabled="False" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
