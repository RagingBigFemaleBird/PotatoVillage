<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:PotatoVillage.Markup"
             x:Class="PotatoVillage.RoomView"
             Title="{m:Translate room_title}">

    <Grid>
        <!-- Background Image -->
        <Image Source="bg.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />

        <Grid RowDefinitions="Auto,*,Auto" Padding="20">
        <!-- Room Info Header with Leave Button -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <VerticalStackLayout Grid.Column="0" Spacing="8">
                <HorizontalStackLayout Spacing="12">
                    <Label Text="{m:Translate room_number_label}" FontAttributes="Bold" FontSize="18" TextColor="#FFF8DC"/>
                    <Label x:Name="RoomNumberLabel" FontSize="18" TextColor="#FFF8DC" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="12">
                    <Label Text="{m:Translate your_seat}" FontAttributes="Bold" FontSize="16" TextColor="#FFF8DC"/>
                    <Label x:Name="YourSeatLabel" FontSize="16" TextColor="#FFF8DC"/>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="12">
                    <Label Text="{m:Translate players_joined}" FontAttributes="Bold" FontSize="14" TextColor="#FFF8DC"/>
                    <Label x:Name="PlayersCountLabel" FontSize="14" TextColor="#FFF8DC"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Leave Room Button (top right) -->
            <!-- No BackgroundColor: lets iOS apply its default Liquid Glass
                 material. Setting any BackgroundColor (even Transparent)
                 disables the system glass effect on iOS Buttons. -->
            <Button x:Name="LeaveRoomBtn" 
                    Grid.Column="1"
                    Text="✕"
                    Clicked="OnLeaveRoomClicked"
                    TextColor="#FFF8DC"
                    FontSize="14"
                    WidthRequest="36"
                    HeightRequest="36"
                    CornerRadius="18"
                    Padding="0"
                    VerticalOptions="Start" />
        </Grid>

        <!-- Player List -->
        <ScrollView Grid.Row="1" Margin="0,20,0,20">
            <VerticalStackLayout Spacing="16">
                <FlexLayout x:Name="PlayerListContainer" 
                            Wrap="Wrap" 
                            JustifyContent="Start"
                            AlignItems="Start"
                            AlignContent="Start">
                    <!-- Player entries will be added dynamically -->
                </FlexLayout>

                <!-- Roles Display -->
                <VerticalStackLayout x:Name="RolesContainer" Spacing="8">
                    <Label Text="{m:Translate roles_in_game}" 
                           FontAttributes="Bold" 
                           FontSize="16" 
                           TextColor="#FFF8DC"
                           Margin="0,8,0,4"/>
                    <FlexLayout x:Name="RolesListContainer" 
                                Wrap="Wrap" 
                                JustifyContent="Start"
                                AlignItems="Start"
                                AlignContent="Start">
                        <!-- Role entries will be added dynamically -->
                    </FlexLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Buttons -->
        <VerticalStackLayout Grid.Row="2" Spacing="12">
            <!-- Notice about dead players -->
            <Border BackgroundColor="#FFF3CD"
                    Stroke="#FFECB5"
                    Padding="10"
                    StrokeShape="RoundRectangle 5">
                <Label x:Name="DeadPlayerNoticeLabel" 
                       Text="{m:Translate dead_player_notice}" 
                       FontSize="12" 
                       TextColor="#856404"
                       LineBreakMode="WordWrap" />
            </Border>

            <!-- Start Game Button (only visible to owner) -->
            <!-- No BackgroundColor (not even Transparent) so iOS applies its
                 default Liquid Glass material, matching GameView buttons. -->
            <Button x:Name="StartGameBtn" 
                    Text="{m:Translate start_game}" 
                    Clicked="OnStartGameClicked"
                    IsVisible="False"
                    TextColor="White"
                    FontSize="18"
                    HeightRequest="50" />
        </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
