<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:PotatoVillage.Markup"
             x:Class="PotatoVillage.RoomView"
             Title="{m:Translate room_title}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20">
        <!-- Room Info Header with Leave Button -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <VerticalStackLayout Grid.Column="0" Spacing="8">
                <HorizontalStackLayout Spacing="12">
                    <Label Text="{m:Translate room_number_label}" FontAttributes="Bold" FontSize="18" />
                    <Label x:Name="RoomNumberLabel" FontSize="18" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="12">
                    <Label Text="{m:Translate your_seat}" FontAttributes="Bold" FontSize="16" />
                    <Label x:Name="YourSeatLabel" FontSize="16" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="12">
                    <Label Text="{m:Translate players_joined}" FontAttributes="Bold" FontSize="14" />
                    <Label x:Name="PlayersCountLabel" FontSize="14" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Leave Room Button (top right) -->
            <Button x:Name="LeaveRoomBtn" 
                    Grid.Column="1"
                    Text="✕"
                    Clicked="OnLeaveRoomClicked"
                    BackgroundColor="#FF3B30"
                    TextColor="White"
                    FontSize="14"
                    WidthRequest="36"
                    HeightRequest="36"
                    CornerRadius="18"
                    Padding="0"
                    VerticalOptions="Start" />
        </Grid>

        <!-- Player List -->
        <ScrollView Grid.Row="1" Margin="0,20,0,20">
            <FlexLayout x:Name="PlayerListContainer" 
                        Wrap="Wrap" 
                        JustifyContent="Start"
                        AlignItems="Start"
                        AlignContent="Start">
                <!-- Player entries will be added dynamically -->
            </FlexLayout>
        </ScrollView>

        <!-- Bottom Buttons -->
        <VerticalStackLayout Grid.Row="2" Spacing="12">
            <!-- Notice about dead players -->
            <Frame BackgroundColor="#FFF3CD" BorderColor="#FFECB5" Padding="10" CornerRadius="5">
                <Label x:Name="DeadPlayerNoticeLabel" 
                       Text="{m:Translate dead_player_notice}" 
                       FontSize="12" 
                       TextColor="#856404"
                       LineBreakMode="WordWrap" />
            </Frame>

            <!-- Start Game Button (only visible to owner) -->
            <Button x:Name="StartGameBtn" 
                    Text="{m:Translate start_game}" 
                    Clicked="OnStartGameClicked"
                    IsVisible="False"
                    BackgroundColor="#007AFF"
                    TextColor="White"
                    FontSize="18"
                    HeightRequest="50" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>
