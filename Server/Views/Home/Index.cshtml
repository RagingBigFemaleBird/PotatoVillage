@{
    ViewData["Title"] = "首页";
}

<div class="text-center">
    <h1 class="display-4">土豆天天村</h1>
    <p class="lead">狼人杀游戏服务器</p>

    <div class="row justify-content-center mt-5">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Game Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-4">
                            <div class="p-3">
                                <h2 class="text-primary">@ViewBag.TotalGames</h2>
                                <p class="text-muted mb-0">Total Games</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3">
                                <h2 class="text-success">@ViewBag.ActiveGames</h2>
                                <p class="text-muted mb-0">In Progress</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3">
                                <h2 class="text-warning">@ViewBag.WaitingGames</h2>
                                <p class="text-muted mb-0">Waiting for Players</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
